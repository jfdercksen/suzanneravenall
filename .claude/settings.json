{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teamateMode": "in-process",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(pg_dump *)",
      "Bash(psql *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(certbot *)",
      "Bash(nginx *)",
      "Bash(systemctl *)",
      "Bash(vitest *)",
      "Bash(turbo *)",
      "Write(*)",
      "Edit(*)",
      "Read(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(DROP DATABASE *)",
      "Bash(DROP TABLE *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Apps/suzanneravenall.com && bash .claude/hooks/block-at-commit.sh",
            "description": "Block commit if tests are not passing"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Apps/suzanneravenall.com && bash .claude/hooks/block-env-edit.sh",
            "description": "Block direct edits to .env files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Apps/suzanneravenall.com && bash .claude/hooks/post-edit.sh",
            "description": "Auto-format and type-check TypeScript/JavaScript files after edits"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Apps/suzanneravenall.com && bash .claude/hooks/skill-evaluator.sh",
            "description": "Suggest relevant skills based on prompt content"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Apps/suzanneravenall.com && bash .claude/hooks/session-start.sh",
            "description": "Load git status, recent log, branch and open TODOs"
          }
        ]
      }
    ]
  }
}