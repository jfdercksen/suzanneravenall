# Copy this file to .env.local and fill in real values
# Never commit .env.local — it is in .gitignore
#
# NOTE: Each app also has its own .env.local:
#   apps/web/.env.local   — Next.js web app (complete set of web vars)
#   apps/payload/.env.local — Payload CMS (DATABASE_URL, PAYLOAD_SECRET, PAYLOAD_URL)
# This root file is a developer reference and is loaded by Turborepo for
# shared vars. Apps read their own .env.local for app-specific vars.

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: both apps connect to Supabase via the same credentials.
# VPS: these point to separate databases on the shared Postgres container.
MEDUSA_DATABASE_URL=postgresql://postgres:password@localhost:5432/medusa
PAYLOAD_DATABASE_URL=postgresql://postgres:password@localhost:5432/payload

# ── Medusa ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000

# ── Payload CMS ──────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-here-generate-with-openssl-rand-hex-32
PAYLOAD_URL=http://localhost:3001

# ── Sentry (Phase 5 — see KI001) ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development

# ── Analytics (confirm IDs with Suzanne before going live) ───────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=your-clarity-id

# ── Email — Resend (Phase 2) ──────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Payments (Phase 2) ───────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ── Sage API (Phase 4) ────────────────────────────────────────────────────────
SAGE_CLIENT_ID=your-sage-client-id
SAGE_CLIENT_SECRET=your-sage-client-secret

# ── Bunny Stream (Phase 3) ───────────────────────────────────────────────────
BUNNY_STREAM_API_KEY=your-bunny-api-key
BUNNY_STREAM_LIBRARY_ID=your-library-id

# ── MeiliSearch ───────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=your-meilisearch-admin-key

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ── Vtiger CRM (Phase 4) ─────────────────────────────────────────────────────
VTIGER_URL=https://your-vtiger-instance.com
VTIGER_USERNAME=your-vtiger-username
VTIGER_ACCESS_KEY=your-vtiger-access-key

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ── Cal.com (Task 1.8) ───────────────────────────────────────────────────────
# VPS (no SSL yet): http://<vps-ip>:3002
# Production (once SSL is provisioned): https://cal.suzanneravenall.com
NEXT_PUBLIC_CAL_URL=http://169.239.180.49:3002

# ── Firecrawl (dev tooling / Claude Code) ────────────────────────────────────
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
