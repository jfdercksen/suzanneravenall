# Copy this file to .env.local and fill in real values
# Never commit .env.local — it is in .gitignore

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ── Medusa ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000

# ── Sentry (deferred to Phase 5 DNS cutover — see KI001) ─────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development

# ── Analytics (confirm IDs with Suzanne before going live) ───────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=your-clarity-id

# ── Email — Resend (Phase 2) ──────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Payments (Phase 2) ───────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ── Sage API (Phase 4) ────────────────────────────────────────────────────────
SAGE_CLIENT_ID=your-sage-client-id
SAGE_CLIENT_SECRET=your-sage-client-secret

# ── Bunny Stream (Phase 3) ───────────────────────────────────────────────────
BUNNY_STREAM_API_KEY=your-bunny-api-key
BUNNY_STREAM_LIBRARY_ID=your-library-id

# ── MeiliSearch ───────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=your-meilisearch-admin-key

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ── Vtiger CRM (Phase 4) ─────────────────────────────────────────────────────
VTIGER_URL=https://your-vtiger-instance.com
VTIGER_USERNAME=your-vtiger-username
VTIGER_ACCESS_KEY=your-vtiger-access-key

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx
