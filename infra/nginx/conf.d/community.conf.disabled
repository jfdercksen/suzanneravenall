# community.suzanneravenall.com — self-hosted Discourse community forum
# Discourse runs its own Docker stack — ensure the discourse container is on suzanne_network

server {
    listen 80;
    server_name community.suzanneravenall.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name community.suzanneravenall.com;

    ssl_certificate     /etc/letsencrypt/live/community.suzanneravenall.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/community.suzanneravenall.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        # Discourse runs its own Docker stack — ensure the discourse container is on suzanne_network
        proxy_pass http://discourse:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
