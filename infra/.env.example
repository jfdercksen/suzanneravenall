# ============================================================
# suzanneravenall.com — VPS production environment
# Copy this file to infra/.env and fill in real values.
# This file is read by docker compose — never commit infra/.env
# ============================================================

# ============================================================
# PostgreSQL — shared Postgres instance (Medusa, n8n, Cal.com)
# ============================================================
POSTGRES_DB=medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# Medusa.js v2 — commerce backend
# Uses the "medusa" database on the shared Postgres instance
# ============================================================
MEDUSA_DATABASE_URL=postgres://medusa:change_me_strong_password@postgres:5432/medusa
NODE_ENV=production
JWT_SECRET=change_me_jwt_secret_min_32_chars
COOKIE_SECRET=change_me_cookie_secret_min_32_chars
MEDUSA_ADMIN_ONBOARDING_TYPE=default
SENTRY_DSN_MEDUSA=https://your-key@sentry.io/your-medusa-project-id

# ============================================================
# Payload CMS — content management
# Uses the "payload" database on the shared Postgres instance
# Run before first deploy:
#   docker exec suzanne_postgres psql -U medusa -c "CREATE DATABASE payload;"
# ============================================================
PAYLOAD_DATABASE_URL=postgres://medusa:change_me_strong_password@postgres:5432/payload
PAYLOAD_SECRET=change_me_payload_secret_min_32_chars
PAYLOAD_URL=https://suzanneravenall.com/cms

# ============================================================
# Next.js — public-facing website
# IMPORTANT: NEXT_PUBLIC_* vars are baked into the browser
# bundle at build time — never use internal Docker hostnames
# ============================================================
NEXT_PUBLIC_SITE_URL=https://suzanneravenall.com
NEXT_PUBLIC_SUPABASE_URL=https://mjhwonoekokxyisfljtj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_MEDUSA_URL=https://suzanneravenall.com/store
MEDUSA_BACKEND_URL=http://medusa:9000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=your-clarity-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-web-project-id
SENTRY_DSN_WEB=https://your-key@sentry.io/your-web-project-id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================
# Email — Resend
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================================
# Payments (Phase 2)
# ============================================================
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ============================================================
# Bunny Stream — video hosting (Phase 3)
# ============================================================
BUNNY_STREAM_API_KEY=your-bunny-api-key
BUNNY_STREAM_LIBRARY_ID=your-library-id

# ============================================================
# MeiliSearch — search
# MEILI_MASTER_KEY is consumed by the meilisearch container.
# MEILISEARCH_HOST / MEILISEARCH_ADMIN_KEY are passed to the
# web container so it can query MeiliSearch internally.
# ============================================================
MEILI_MASTER_KEY=change_me_meilisearch_master_key
MEILI_ENV=production
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_ADMIN_KEY=change_me_meilisearch_master_key

# ============================================================
# n8n — automation
# ============================================================
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key
N8N_HOST=n8n.suzanneravenall.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.suzanneravenall.com
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=medusa
DB_POSTGRESDB_PASSWORD=change_me_strong_password
N8N_WEBHOOK_SECRET=change_me_n8n_webhook_secret

# ============================================================
# Cal.com — booking
# Note: Cal.com database URL is constructed inline in
# docker-compose using POSTGRES_PASSWORD — no separate var.
# Ensure "calcom" database exists before first run:
#   docker exec suzanne_postgres psql -U medusa -c "CREATE DATABASE calcom;"
# ============================================================
NEXT_PUBLIC_WEBAPP_URL=https://cal.suzanneravenall.com
CALENDSO_ENCRYPTION_KEY=change_me_calcom_encryption_key
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=https://cal.suzanneravenall.com
EMAIL_FROM=noreply@suzanneravenall.com
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your_resend_api_key

# ============================================================
# Vtiger CRM (Phase 4)
# ============================================================
VTIGER_URL=https://your-vtiger-instance.com
VTIGER_USERNAME=your-vtiger-username
VTIGER_ACCESS_KEY=your-vtiger-access-key

# ============================================================
# Sage Business Cloud API (Phase 4)
# ============================================================
SAGE_CLIENT_ID=your-sage-client-id
SAGE_CLIENT_SECRET=your-sage-client-secret

# ============================================================
# Anthropic — Claude API
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ============================================================
# Firecrawl — web scraping (used by Claude Code / dev tooling)
# ============================================================
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Backblaze B2 — automated backups
# ============================================================
B2_BUCKET_NAME=your-backblaze-bucket-name
B2_KEY_ID=your-backblaze-key-id
B2_APPLICATION_KEY=your-backblaze-application-key

# ============================================================
# Slack — deployment and backup failure notifications
# Also used in GitHub Actions deploy.yml (SLACK_WEBHOOK_URL secret)
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
