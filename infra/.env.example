# ============================================================
# Environment variable template for suzanneravenall.com
# Copy this file to .env and fill in real values before
# running docker compose up. Never commit the .env file.
# ============================================================

# ============================================================
# PostgreSQL (shared database for Medusa, Payload, and n8n)
# ============================================================
# Name of the default Postgres database (used by Medusa)
POSTGRES_DB=medusa
# Postgres superuser username
POSTGRES_USER=medusa
# Postgres superuser password — use a strong random string in production
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# Medusa.js
# ============================================================
# Full connection string — host must match the Docker service name "postgres"
DATABASE_URL=postgres://medusa:change_me_strong_password@postgres:5432/medusa
# "production" or "development"
NODE_ENV=production
# Random string, minimum 32 characters — used to sign JWTs
JWT_SECRET=change_me_jwt_secret_min_32_chars
# Random string, minimum 32 characters — used to sign session cookies
COOKIE_SECRET=change_me_cookie_secret_min_32_chars
# Onboarding flow type shown in the Medusa Admin dashboard
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# ============================================================
# Next.js (web)
# ============================================================
# Supabase project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Medusa storefront API URL — uses Docker service hostname internally
NEXT_PUBLIC_MEDUSA_URL=http://medusa:9000
# Canonical public URL for the site
NEXT_PUBLIC_SITE_URL=https://suzanneravenall.com
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# Payload CMS
# ============================================================
# Random string, minimum 32 characters — used to sign Payload tokens
PAYLOAD_SECRET=change_me_payload_secret_min_32_chars
# Payload uses its own database — separate from the Medusa database
DATABASE_URI=postgres://medusa:change_me_strong_password@postgres:5432/payload
# Public URL where the Payload CMS admin is reachable
PAYLOAD_PUBLIC_SERVER_URL=https://suzanneravenall.com/cms

# ============================================================
# MeiliSearch
# ============================================================
# Master key — all API calls require this. Use a strong random string.
MEILI_MASTER_KEY=change_me_meilisearch_master_key
# "production" disables the MeiliSearch web UI and analytics
MEILI_ENV=production

# ============================================================
# n8n
# ============================================================
# Random string used to encrypt credentials stored by n8n
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key
# Public hostname where n8n is accessible (no protocol prefix)
N8N_HOST=n8n.suzanneravenall.com
# Internal port n8n listens on
N8N_PORT=5678
# Protocol used for the public URL
N8N_PROTOCOL=https
# Full public webhook base URL — must match the public domain
WEBHOOK_URL=https://n8n.suzanneravenall.com
# Database backend for n8n — use postgresdb for production
DB_TYPE=postgresdb
# Docker service hostname for the Postgres container
DB_POSTGRESDB_HOST=postgres
# Database name for n8n — must be created before first run
DB_POSTGRESDB_DATABASE=n8n
# Postgres username — reuses the Medusa user
DB_POSTGRESDB_USER=medusa
# Postgres password — must match POSTGRES_PASSWORD above
DB_POSTGRESDB_PASSWORD=change_me_strong_password

# ============================================================
# Cal.com
# ============================================================
# Full public URL for the Cal.com instance
NEXT_PUBLIC_WEBAPP_URL=https://cal.suzanneravenall.com
# Random string used to encrypt Cal.com data at rest
CALENDSO_ENCRYPTION_KEY=change_me_calcom_encryption_key
# Random string used to sign NextAuth session tokens
NEXTAUTH_SECRET=change_me_nextauth_secret
# Full public URL — must match NEXT_PUBLIC_WEBAPP_URL
NEXTAUTH_URL=https://cal.suzanneravenall.com
# From address used for Cal.com outgoing email
EMAIL_FROM=noreply@suzanneravenall.com
# SMTP host — using Resend's SMTP relay
EMAIL_SERVER_HOST=smtp.resend.com
# SMTP port — 465 for TLS
EMAIL_SERVER_PORT=465
# SMTP username for Resend
EMAIL_SERVER_USER=resend
# Resend API key — used as the SMTP password
EMAIL_SERVER_PASSWORD=your_resend_api_key
# Cal.com database — separate database on the shared postgres instance
CALCOM_DATABASE_URL=postgresql://medusa:change_me@postgres:5432/calcom

# ============================================================
# Backblaze B2 (automated backups)
# ============================================================
# B2 bucket name — create at backblaze.com
B2_BUCKET_NAME=your-backblaze-bucket-name
# Application key ID — from Backblaze B2 → App Keys
B2_KEY_ID=your-backblaze-key-id
# Application key secret
B2_APPLICATION_KEY=your-backblaze-application-key
# (optional) Slack incoming webhook URL — receives failure alerts from backup.sh
SLACK_WEBHOOK_URL=

# ============================================================
# Sentry — error monitoring
# ============================================================
# Get DSN from sentry.io → Project Settings → Client Keys
# Web project DSN — safe to expose to browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-web-project-id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Server-side DSN for web (same value as NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN_WEB=https://your-key@sentry.io/your-web-project-id
# Medusa backend DSN — separate Sentry project
SENTRY_DSN_MEDUSA=https://your-key@sentry.io/your-medusa-project-id
# Environment tag shown in Sentry — production, staging, or development
SENTRY_ENVIRONMENT=production
# Auth token for source map uploads — sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token
